# ============================================================================
# CONFIGURACIÓN DEL SISTEMA - INVENTARIO CANNON
# ============================================================================

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventario_cannon
DB_USER=root
DB_PASSWORD=Root@123

# Flask
SECRET_KEY=tu_clave_secreta_muy_larga_y_aleatoria_aqui
FLASK_ENV=development
DEBUG=True

# Mercado Libre API
# Estas credenciales las obtendrás al registrar tu aplicación en developers.mercadolibre.com
ML_APP_ID=
ML_SECRET_KEY=
ML_REDIRECT_URI=http://localhost:5000/ml/callback

# Sincronización automática
SYNC_AUTO_ENABLED=True
SYNC_INTERVAL_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/sistema.log

# Timezone
TIMEZONE=America/Argentina/Buenos_Aires
